{
  "name": "readbase-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:ui": "node scripts/dev-ui.mjs",
    "mock:server": "node mock/server.mjs",
    "generate:api-types": "cd .. && python3 scripts/generate_api_types.py",
    "build": "tsc -p tsconfig.json && vite build",
    "check": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.13"
  }
}
