# Optional. When both values are set, answers are synthesized by an LLM.
# Without these values, the app returns retrieved evidence snippets.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Optional. Defaults to .readbase under the project root.
READBASE_DATA_DIR=.readbase

# Storage routing: saas (default) or customer-owned storage.
# READBASE_DEPLOYMENT_MODE=saas
# READBASE_ORG_STORAGE_ROOT=/mnt/customer-readbase
# READBASE_SCRATCH_DIR=/tmp/readbase-scratch

# PostgreSQL database used for users, workspace metadata, and memberships.
# Example: postgresql+psycopg://readbase:readbase@127.0.0.1:5432/readbase
DATABASE_URL=

# Required for Google OAuth login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override for callback URI. Must exactly match Google Console.
# Example: http://127.0.0.1:8000/api/auth/callback
GOOGLE_REDIRECT_URI=

# Org-specific OIDC login (defaults to Google env vars above when unset).
# READBASE_OIDC_CLIENT_ID=
# READBASE_OIDC_CLIENT_SECRET=
# READBASE_OIDC_ISSUER=https://accounts.google.com
# READBASE_OIDC_AUTHORIZE_URL=
# READBASE_OIDC_TOKEN_URL=
# READBASE_OIDC_JWKS_URL=
# READBASE_OIDC_REDIRECT_URI=http://127.0.0.1:8000/api/auth/callback
# READBASE_OIDC_SCOPES=openid email profile
# READBASE_OIDC_PROVIDER_NAME=your organization

# Required for secure app sessions.
APP_SESSION_SECRET=replace-with-a-long-random-secret

# Optional. Access token lifetime in seconds (default 3600 = 1 hour).
APP_ACCESS_TOKEN_MAX_AGE_SECONDS=3600

# Optional. Refresh token lifetime in seconds (default 604800 = 7 days).
APP_REFRESH_TOKEN_MAX_AGE_SECONDS=604800

# Optional. Revoke idle sessions after this many seconds (default 86400 = 24 hours).
APP_SESSION_IDLE_TIMEOUT_SECONDS=86400

# Set to production to enforce secure cookies, secret validation, and HTTPS expectations.
# APP_ENV=production

# Optional. Post security anomaly payloads to this URL (JSON POST).
# APP_SECURITY_WEBHOOK_URL=

# Optional. Lockout after repeated failed logins (defaults shown).
# APP_AUTH_LOCKOUT_WINDOW_SECONDS=900
# APP_AUTH_LOCKOUT_MAX_FAILURES=5
# APP_AUTH_LOCKOUT_BASE_SECONDS=60
# APP_AUTH_LOCKOUT_MAX_SECONDS=3600

# Optional. Security anomaly detection thresholds per 5-minute window.
# APP_SECURITY_ANOMALY_WINDOW_SECONDS=300
# APP_SECURITY_ANOMALY_AUTH_LOGIN_FAILED=10

# Optional. Refresh session when remaining time is below this threshold.
# Default 900 = 15 minutes (access token only).
APP_ACCESS_TOKEN_REFRESH_WINDOW_SECONDS=900

# Optional. Public app URL used by OAuth callback (default http://127.0.0.1:8000).
# With local mkcert HTTPS, use https://127.0.0.1:8000 and set READBASE_SSL_* below.
APP_BASE_URL=http://127.0.0.1:8000

# Optional. Set true only when serving over HTTPS.
APP_SESSION_COOKIE_SECURE=false

# Optional but strongly recommended. Encrypts stored connector OAuth tokens (AES-256-GCM).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
READBASE_TOKEN_ENCRYPTION_KEY=
# Optional key version label for rotation (default k1).
# READBASE_TOKEN_KEY_VERSION=k1
# Optional per-version keys: READBASE_TOKEN_ENCRYPTION_KEY_K1=

# Required for Jira OAuth connector.
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# Optional override. Must exactly match the Atlassian developer app callback URL.
JIRA_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/jira/callback
# Optional. Keep offline_access for refresh tokens.
JIRA_OAUTH_SCOPES=read:jira-work read:jira-user offline_access

# Required for GitHub OAuth connector.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional override. Must exactly match the GitHub OAuth app callback URL.
GITHUB_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/github/callback
# Optional. repo is required for private repository access checks and cloning.
GITHUB_OAUTH_SCOPES=repo read:user

# Required for Slack OAuth connector.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Optional override. Must exactly match the Slack app redirect URL.
# Local HTTPS (mkcert): run scripts/setup_local_ssl.sh, then use https://127.0.0.1:8000/...
SLACK_REDIRECT_URI=https://127.0.0.1:8000/api/me/integrations/slack/callback
# Optional. User token scopes used for channel suggestions, history sync, and live access checks.
SLACK_USER_SCOPES=channels:read,groups:read,channels:history,groups:history,users:read,team:read

# Required for Microsoft Teams OAuth connector.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Optional. Defaults to organizations. Use a tenant ID for single-tenant apps.
MICROSOFT_TENANT_ID=organizations
# Optional override. Must exactly match the Microsoft Entra app redirect URI.
MICROSOFT_TEAMS_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/teams/callback
# Optional. Keep offline_access for refresh tokens.
MICROSOFT_TEAMS_OAUTH_SCOPES=User.Read Team.ReadBasic.All offline_access

# Required for Bitbucket Cloud OAuth connector.
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
BITBUCKET_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/bitbucket/callback
BITBUCKET_OAUTH_SCOPES=account repository

# Required for GitLab.com OAuth connector.
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/gitlab/callback
GITLAB_OAUTH_SCOPES=read_user read_api read_repository

# Required for Linear OAuth connector.
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/linear/callback
LINEAR_OAUTH_SCOPES=read

# Required for Confluence Cloud OAuth connector.
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=
CONFLUENCE_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/confluence/callback
CONFLUENCE_OAUTH_SCOPES=read:space:confluence read:page:confluence read:confluence-space.summary read:confluence-content.all offline_access

# Required for Notion OAuth connector. Notion only accepts https redirect URIs.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Must match exactly what you register under OAuth Domain & URIs in Notion.
# Local dev: enable READBASE_SSL_* below, then use https://127.0.0.1:8000/...
# Or use a tunnel (ngrok, Cloudflare Tunnel) and paste its https callback URL here.
NOTION_REDIRECT_URI=https://127.0.0.1:8000/api/me/integrations/notion/callback
# Optional. Public https origin when not using NOTION_REDIRECT_URI (auto-upgrades http when SSL is on).
# NOTION_PUBLIC_BASE_URL=https://127.0.0.1:8000
# Optional local HTTPS for dev (run scripts/setup_local_ssl.sh; required for Slack Public Distribution).
# READBASE_SSL_CERTFILE=certs/readbase-local.pem
# READBASE_SSL_KEYFILE=certs/readbase-local-key.pem