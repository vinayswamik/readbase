# Optional. When both values are set, answers are synthesized by an LLM.
# Without these values, the app returns retrieved evidence snippets.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Optional. Defaults to .readbase under the project root.
READBASE_DATA_DIR=.readbase

# PostgreSQL database used for users, admin approvals, workspace metadata, and memberships.
# Example: postgresql+psycopg://readbase:readbase@127.0.0.1:5432/readbase
DATABASE_URL=

# Comma-separated Google account emails allowed to use Admin Login.
READBASE_BOOTSTRAP_ADMIN_EMAILS=

# Required for Google OAuth login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override for callback URI. Must exactly match Google Console.
# Example: http://127.0.0.1:8000/api/auth/google/callback
GOOGLE_REDIRECT_URI=

# Required for secure app sessions.
APP_SESSION_SECRET=replace-with-a-long-random-secret

# Optional. Access token lifetime in seconds (default 3600 = 1 hour).
APP_ACCESS_TOKEN_MAX_AGE_SECONDS=3600

# Optional. Refresh token lifetime in seconds (default 2592000 = 30 days).
APP_REFRESH_TOKEN_MAX_AGE_SECONDS=2592000

# Optional. Refresh session when remaining time is below this threshold.
# Default 900 = 15 minutes (access token only).
APP_ACCESS_TOKEN_REFRESH_WINDOW_SECONDS=900

# Optional. Public app URL used by OAuth callback (default http://127.0.0.1:8000).
APP_BASE_URL=http://127.0.0.1:8000

# Optional. Set true only when serving over HTTPS.
APP_SESSION_COOKIE_SECURE=false

# Optional but strongly recommended. Encrypts stored Jira/GitHub OAuth tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
READBASE_TOKEN_ENCRYPTION_KEY=

# Required for Jira OAuth connector.
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# Optional override. Must exactly match the Atlassian developer app callback URL.
JIRA_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/jira/callback
# Optional. Keep offline_access for refresh tokens.
JIRA_OAUTH_SCOPES=read:jira-work read:jira-user offline_access

# Required for GitHub OAuth connector.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Optional override. Must exactly match the GitHub OAuth app callback URL.
GITHUB_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/github/callback
# Optional. repo is required for private repository access checks and cloning.
GITHUB_OAUTH_SCOPES=repo read:user

# Required for Slack OAuth connector.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Optional override. Must exactly match the Slack app redirect URL.
SLACK_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/slack/callback
# Optional. User token scopes used for channel suggestions, history sync, and live access checks.
SLACK_USER_SCOPES=channels:read,groups:read,channels:history,groups:history,users:read,team:read

# Required for Bitbucket Cloud OAuth connector.
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
BITBUCKET_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/bitbucket/callback
BITBUCKET_OAUTH_SCOPES=account repository

# Required for GitLab.com OAuth connector.
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/gitlab/callback
GITLAB_OAUTH_SCOPES=read_user read_api read_repository

# Required for Linear OAuth connector.
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/linear/callback
LINEAR_OAUTH_SCOPES=read

# Required for Confluence Cloud OAuth connector.
CONFLUENCE_CLIENT_ID=
CONFLUENCE_CLIENT_SECRET=
CONFLUENCE_REDIRECT_URI=http://127.0.0.1:8000/api/me/integrations/confluence/callback
CONFLUENCE_OAUTH_SCOPES=read:space:confluence read:page:confluence read:confluence-space.summary read:confluence-content.all offline_access
